!(import! &self mork)
!(bind! &h (new-space hash))
!(space-set-backend! &h pathmap)
!(add-atom &h (edge a b))
!(assertEqualToResult (match &h (edge a b) hit) (hit))
!(add-atom &h (edge b c))
!(assertEqualToResult (size &h) (2))
!(assertEqualToResult (match &h (edge b c) hit) (hit))
!(remove-atom &h (edge a b))
!(assertEqualToResult (size &h) (1))
!(assertEqualToResult (match &h (edge a b) hit) ())
!(assertEqualToResult (match &h (edge b c) hit) (hit))
!(space-set-backend! &h native-candidate-exact)
!(assertEqualToResult (size &h) (1))
!(assertEqualToResult (match &h (edge b c) hit) (hit))
