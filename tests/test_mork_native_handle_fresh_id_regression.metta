!(include mork)
!(bind! &mork-h1 (mork:new-space))
!(mork:add-atoms &mork-h1 ((h 1) (h 2) (h 3)))
!(bind! &mork-h2 (mork:new-space))
!(assertEqualToResult (mork:size &mork-h2) (0))
!(mork:add-atom &mork-h2 (fresh two))
!(assertEqualToResult (mork:size &mork-h1) (3))
!(assertEqualToResult (mork:size &mork-h2) (1))
!(bind! &mork-h3 (mork:new-space))
!(assertEqualToResult (mork:size &mork-h3) (0))
