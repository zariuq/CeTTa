!(pl-consult "tests/support/foreign_prolog_simple.pl")
!(bind! &plus1 (pl-atom prolog_probe_add1))
!(assertEqual (&plus1 41) 42)
!(import_prolog_function prolog_probe_echo)
!(assertEqual (prolog_probe_echo "hello") "hello")
!(assertEqual ((pl-atom prolog_probe_pair) 1 2) (1 2))
!(assertEqual (Predicate prolog_probe_pair 1 2) (prolog_probe_pair 1 2))
!(assertEqual (callPredicate (Predicate prolog_probe_fact alpha)) true)
!(assertEqual (callPredicate prolog_probe_fact beta) false)
!(assertEqual (callPredicate (Predicate prolog_probe_dyn foo)) false)
!(assertEqual (assertzPredicate (Predicate prolog_probe_dyn foo)) true)
!(assertEqual (callPredicate prolog_probe_dyn foo) true)
!(assertEqual (retractPredicate (Predicate prolog_probe_dyn foo)) true)
!(assertEqual (callPredicate prolog_probe_dyn foo) false)
