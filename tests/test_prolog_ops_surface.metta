!(pl-consult "tests/support/foreign_prolog_simple.pl")
!(bind! &plus1 (pl-atom prolog_probe_add1))
!(assertEqual (&plus1 41) 42)
!(pl-import prolog_probe_echo)
!(assertEqual (prolog_probe_echo "hello") "hello")
!(assertEqual (prolog_probe_echo "hello Zar") "hello Zar")
!(assertEqual (prolog_probe_echo "quote \"inside\"") "quote \"inside\"")
!(assertEqual (prolog_probe_echo sample-symbol) sample-symbol)
!(assertEqual (prolog_probe_echo True) True)
!(assertEqual ((pl-atom prolog_probe_pair) 1 2) (1 2))
!(bind! &compound (pl-atom prolog_probe_compound))
!(assertEqual (&compound) (wrapper alpha 7))
!(bind! &choice (pl-atom prolog_probe_choice))
!(assertEqualToResult (&choice) (red blue))
!(assertEqual (Predicate prolog_probe_pair 1 2) (prolog_probe_pair 1 2))
!(assertEqual (pl-call (Predicate prolog_probe_fact alpha)) True)
!(assertEqual (pl-call (Predicate prolog_probe_fact beta)) False)
!(assertEqual (pl-call (Predicate prolog_probe_dyn foo)) False)
!(assertEqual (pl-assertz (Predicate prolog_probe_dyn foo)) True)
!(assertEqual (pl-call prolog_probe_dyn foo) True)
!(assertEqual (pl-retract (Predicate prolog_probe_dyn foo)) True)
!(assertEqual (pl-call prolog_probe_dyn foo) False)
!(assertEqual (pl-asserta (Predicate prolog_probe_dyn bar)) True)
!(assertEqual (callPredicate prolog_probe_dyn bar) True)
!(assertEqual (retractPredicate (Predicate prolog_probe_dyn bar)) True)
