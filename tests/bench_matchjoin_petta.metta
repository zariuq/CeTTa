(= (twohop)
   (match &self (edge $x $y)
     (match &self (edge $y $z)
       (path $x $y $z))))

(= (merge $a $b) (+ $a $b))
(= (twohop-item)
   (let $p (twohop) 1))

!(foldall merge (twohop-item) 0)
