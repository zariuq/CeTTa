!(import! &self text_cursor)

!(assertEqual (text-cursor "abc") (TextCursor "abc" 0))
!(assertEqual (text-cursor-from "abc" 2) (TextCursor "abc" 2))
!(assertEqual (text-cursor-text (TextCursor "abc" 1)) "abc")
!(assertEqual (text-cursor-pos (TextCursor "abc" 1)) 1)
!(assertEqual (text-cursor-done? (TextCursor "abc" 0)) False)
!(assertEqual (text-cursor-done? (TextCursor "abc" 3)) True)
!(assertEqual (text-cursor-rest (TextCursor "abcdef" 2)) "cdef")
!(assertEqual (text-cursor-peek (TextCursor "abcdef" 2)) "c")
!(assertEqual (text-cursor-peek (TextCursor "abcdef" 6)) Empty)
!(assertEqual (text-cursor-peek-n (TextCursor "abcdef" 2) 3) "cde")
!(assertEqual (text-cursor-peek-n (TextCursor "abcdef" 5) 3) "f")
!(assertEqual (text-cursor-advance (TextCursor "abcdef" 2) 3) (TextCursor "abcdef" 5))
!(assertEqual (text-cursor-advance (TextCursor "abcdef" 5) 3) (TextCursor "abcdef" 6))
!(assertEqual (text-char-whitespace? " ") True)
!(assertEqual (text-char-whitespace? "\n") True)
!(assertEqual (text-char-whitespace? "x") False)
!(assertEqual (text-cursor-skip-whitespace (TextCursor "  \tabc" 0)) (TextCursor "  \tabc" 3))
!(assertEqual (text-cursor-prefix? (TextCursor "demo0.mm" 5) ".mm") True)
!(assertEqual (text-cursor-prefix? (TextCursor "demo0.mm" 5) ".bad") False)
!(assertEqual (text-cursor-consume-prefix (TextCursor "demo0.mm" 5) ".mm") (TextCursor "demo0.mm" 8))
!(assertEqual (text-cursor-consume-prefix (TextCursor "demo0.mm" 5) ".bad") Empty)
!(assertEqual (text-find-from "abcabc" 2 "ca") 2)
!(assertEqual (text-find-from "abcabc" 3 "ca") Empty)
!(assertEqual (text-cursor-find (TextCursor "abcabc" 2) "bc") 4)
