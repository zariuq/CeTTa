!(import! &self text_stream)

!(assertEqual (text-stream "abc") (TextCursor "abc" 0))
!(assertEqual (text-stream-from "abc" 2) (TextCursor "abc" 2))
!(assertEqual (text-stream-pos (TextCursor "abc" 2)) 2)
!(assertEqual (text-stream-rest (TextCursor "abc" 1)) "bc")
!(assertEqual (text-stream-peek (TextCursor "abc" 1)) "b")
!(assertEqual (text-stream-peek-n (TextCursor "abcdef" 2) 3) "cde")
!(assertEqual (text-stream-read-token (TextCursor "  abc def" 0)) (TokenResult "abc" (TextCursor "  abc def" 5)))
!(assertEqual (text-stream-read-token (TextCursor "  abc def" 5)) (TokenResult "def" (TextCursor "  abc def" 9)))
!(assertEqual (text-stream-read-token (TextCursor "   " 0)) Empty)
!(assertEqual (text-stream-read-until (TextCursor "alpha::beta" 0) "::") (ReadUntilResult "alpha" (TextCursor "alpha::beta" 5)))
!(assertEqual (text-stream-prefix? (TextCursor "demo0.mm" 5) ".mm") True)
!(assertEqual (text-stream-consume-prefix (TextCursor "demo0.mm" 5) ".mm") (TextCursor "demo0.mm" 8))
