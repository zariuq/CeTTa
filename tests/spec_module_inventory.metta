; CeTTa extension: programmatic module inventory as a queryable space, following
; HE's own note that print-mods! should eventually become a space-like surface.
!(register-module! support/import_pkg)
!(bind! &m (mod-space! import_pkg:moduleA))
!(bind! &mods (module-inventory!))
!(assertEqualToResult (match &mods (module-profile he_extended) ok) (ok))
!(assertEqualToResult (match &mods (module-provider registered-root enabled) ok) (ok))
!(assertEqualToResult (match &mods (module-provider relative-file enabled) ok) (ok))
!(assertEqualToResult (match &mods (module-provider git-remote enabled) ok) (ok))
!(assertEqualToResult (match &mods (module-provider-implementation registered-root implemented) ok) (ok))
!(assertEqualToResult (match &mods (module-provider-implementation git-remote implemented) ok) (ok))
!(assertEqualToResult (match &mods (module-provider-transport registered-root local) ok) (ok))
!(assertEqualToResult (match &mods (module-provider-transport git-remote remote) ok) (ok))
!(assertEqualToResult (match &mods (module-provider-cache-policy registered-root no-cache) ok) (ok))
!(assertEqualToResult (match &mods (module-provider-cache-policy git-remote cache-backed) ok) (ok))
!(assertEqualToResult (match &mods (module-provider-locator-kind registered-root filesystem-path) ok) (ok))
!(assertEqualToResult (match &mods (module-provider-locator-kind git-remote git-url) ok) (ok))
!(assertEqualToResult (match &mods (module-provider-update-policy registered-root manual-register) ok) (ok))
!(assertEqualToResult (match &mods (module-provider-update-policy git-remote try-fetch-latest) ok) (ok))
!(assertEqualToResult (match &mods (module-provider-revision-policy registered-root none) ok) (ok))
!(assertEqualToResult (match &mods (module-provider-revision-policy git-remote default-branch-only) ok) (ok))
!(assertEqualToResult (match &mods (module-mount import_pkg $path registered-root) ok) (ok))
!(assertEqualToResult (match &mods (module-mount-source import_pkg $path filesystem-path) ok) (ok))
!(assertEqualToResult (match &mods (module-mount-revision-policy import_pkg none "none") ok) (ok))
!(assertEqualToResult (match &mods (loaded-module "import_pkg:moduleA" $path registered-root) ok) (ok))
!(assertEqualToResult (match &mods (loaded-module "Helper" $path relative-file) ok) (ok))
!(assertEqualToResult (match &mods (loaded-module-space "import_pkg:moduleA" $space registered-root) ok) (ok))
