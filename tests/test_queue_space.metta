!(bind! &q (new-space queue))
!(assertEqualToResult (space-kind &q) (queue))
!(assertEqualToResult (space-capabilities &q)
  ((ordered queue fifo match push peek pop get truncate len snapshot)))
!(assertEqualToResult (space-len &q) (0))
!(space-push &q alpha)
!(space-push &q beta)
!(space-push &q gamma)
!(assertEqualToResult (space-get &q 0) (alpha))
!(assertEqualToResult (space-get &q 1) (beta))
!(assertEqualToResult (space-get &q 2) (gamma))
!(assertEqualToResult (space-peek &q) (alpha))
!(assertEqualToResult (get-atoms &q) (alpha beta gamma))
!(assertEqualToResult (space-pop &q) (alpha))
!(assertEqualToResult (space-peek &q) (beta))
!(remove-atom &q beta)
!(assertEqualToResult (get-atoms &q) (gamma))
!(space-push &q delta)
!(assertEqualToResult (get-atoms &q) (gamma delta))
!(space-truncate &q 1)
!(assertEqualToResult (space-len &q) (1))
!(assertEqualToResult (space-peek &q) (gamma))
