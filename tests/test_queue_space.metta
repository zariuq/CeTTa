!(bind! &q (new-space queue))
!(assertEqualToResult (space-kind &q) (queue))
!(assertEqualToResult (space-capabilities &q)
  ((ordered queue fifo match push peek pop get truncate len snapshot)))
!(assertEqualToResult (space-len &q) (0))
!(space-push &q alpha)
!(space-push &q beta)
!(space-push &q gamma)
!(assertEqualToResult (space-get &q 0) (alpha))
!(assertEqualToResult (space-get &q 1) (beta))
!(assertEqualToResult (space-get &q 2) (gamma))
!(assertEqualToResult (space-peek &q) (alpha))
!(assertEqualToResult (get-atoms &q) (alpha beta gamma))
!(assertEqualToResult (space-pop &q) (alpha))
!(assertEqualToResult (space-peek &q) (beta))
!(remove-atom &q beta)
!(assertEqualToResult (get-atoms &q) (gamma))
!(space-push &q delta)
!(assertEqualToResult (get-atoms &q) (gamma delta))
!(space-truncate &q 1)
!(assertEqualToResult (space-len &q) (1))
!(assertEqualToResult (space-peek &q) (gamma))

(= (queue-push-range $q $i $limit)
   (if (> $i $limit)
       done
       (let* ((() (space-push $q $i))
              ($next (+ $i 1)))
         (queue-push-range $q $next $limit))))

(= (queue-pop-count $q $n)
   (if (<= $n 0)
       done
       (let* (($dropped (space-pop $q))
              ($rest (- $n 1)))
         (queue-pop-count $q $rest))))

!(bind! &q2 (new-space queue))
!(assertEqual (queue-push-range &q2 1 70) done)
!(assertEqual (queue-pop-count &q2 60) done)
!(assertEqualToResult (space-peek &q2) (61))
!(assertEqual (queue-push-range &q2 71 120) done)
!(assertEqualToResult (space-len &q2) (60))
!(assertEqualToResult (space-peek &q2) (61))
!(assertEqualToResult (space-get &q2 0) (61))
!(assertEqualToResult (space-get &q2 9) (70))
!(assertEqualToResult (space-get &q2 10) (71))
!(assertEqualToResult (space-get &q2 59) (120))
!(assertEqualToResult (space-pop &q2) (61))
!(assertEqualToResult (space-pop &q2) (62))
!(assertEqualToResult (space-peek &q2) (63))
