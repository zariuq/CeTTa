!(let* (($s (new-space native))
        ($t0 (space-set-match-backend! $s native))
        ($t1 (add-atom $s (fill 1)))
        ($t2 (add-atom $s (fill 2)))
        ($t3 (add-atom $s (fill 3)))
        ($t4 (add-atom $s (fill 4)))
        ($t5 (add-atom $s (fill 5)))
        ($t6 (add-atom $s (fill 6)))
        ($t7 (add-atom $s (fill 7)))
        ($t8 (add-atom $s (fill 8)))
        ($t9 (add-atom $s (fill 9)))
        ($t10 (add-atom $s (fill 10)))
        ($t11 (add-atom $s (fill 11)))
        ($t12 (add-atom $s (fill 12)))
        ($t13 (add-atom $s (fill 13)))
        ($t14 (add-atom $s (fill 14)))
        ($t15 (add-atom $s (fill 15)))
        ($t16 (add-atom $s (fill 16)))
        ($warm (match $s (fill 1) warmed))
        ($t17 (add-atom $s (coref a b)))
        ($t18 (add-atom $s (coref z z))))
    (assertEqualToResult
        (match $s (coref $x $x) (hit $x))
        ((hit z))))
