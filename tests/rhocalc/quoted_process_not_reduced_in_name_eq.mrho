; Quoted processes are names; COMM must not reduce inside a quote to compare names.
(rho:par
  (rho:send
    (rho:quote
      (rho:par
        (rho:recv (rho:quote rho:nil) $x (rho:drop $x))
        (rho:send (rho:quote rho:nil) rho:nil)))
    rho:nil)
  (rho:recv (rho:quote rho:nil) $y (rho:drop $y)))
