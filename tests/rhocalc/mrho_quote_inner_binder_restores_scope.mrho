; Quoted binders must not corrupt the surrounding mrho elaborator stack.
(rho:par
  (rho:recv (rho:quote rho:nil) $x
    (rho:par
      (rho:send
        (rho:quote
          (rho:recv (rho:quote rho:nil) $y (rho:drop $y)))
        rho:nil)
      (rho:send $x rho:nil)))
  (rho:send
    (rho:quote rho:nil)
    (rho:send (rho:quote rho:nil) rho:nil)))
