; One COMM substitutes elsewhere in the continuation, but the literal quoted
; process under this drop was always present and must stay inert in the
; one-step successor.
(rho:par
  (rho:recv (rho:quote rho:nil) $x
    (rho:drop (rho:quote (rho:send (rho:quote rho:nil) rho:nil))))
  (rho:send (rho:quote rho:nil) rho:nil))
