; One top-level COMM on @{0} should fire, while the unrelated send/recv on
; different channels remain because channel names must match exactly.
(rho:par
  (rho:send (rho:quote rho:nil) rho:nil)
  (rho:recv (rho:quote rho:nil) $x rho:nil)
  (rho:send
    (rho:quote (rho:send (rho:quote rho:nil) rho:nil))
    rho:nil)
  (rho:recv
    (rho:quote (rho:recv (rho:quote rho:nil) $z rho:nil))
    $y
    rho:nil))
