(rho:par
  (rho:send (rho:quote rho:nil) rho:nil)
  (rho:recv (rho:quote rho:nil) $msg
    (rho:send (rho:quote (rho:send (rho:quote rho:nil) rho:nil))
      (rho:drop $msg)))
  (rho:recv (rho:quote (rho:send (rho:quote rho:nil) rho:nil)) $msg
    (rho:send (rho:quote (rho:recv (rho:quote rho:nil) $done rho:nil))
      (rho:drop $msg)))
  (rho:recv (rho:quote (rho:recv (rho:quote rho:nil) $done rho:nil)) $done
    rho:nil))
