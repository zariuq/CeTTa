(= (threehop)
   (match &self (edge $x $y)
     (match &self (edge $y $z)
       (match &self (edge $z $w)
         (path3 $x $y $z $w)))))

(= (merge $a $b) (+ $a $b))
(= (threehop-item)
   (let $p (threehop) 1))

!(foldall merge (threehop-item) 0)
