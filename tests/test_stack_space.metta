!(bind! &stk (new-space stack))
!(assertEqualToResult (space-kind &stk) (stack))
!(assertEqualToResult (space-capabilities &stk)
  ((ordered stack lifo match push peek pop get truncate len snapshot)))
!(assertEqualToResult (space-len &stk) (0))
!(space-push &stk alpha)
!(space-push &stk beta)
!(assertEqualToResult (space-get &stk 0) (alpha))
!(assertEqualToResult (space-get &stk 1) (beta))
!(assertEqualToResult (space-peek &stk) (beta))
!(assertEqualToResult (get-atoms &stk) (alpha beta))
!(assertEqualToResult (space-pop &stk) (beta))
!(assertEqualToResult (space-peek &stk) (alpha))
!(space-truncate &stk 0)
!(assertEqualToResult (space-len &stk) (0))
!(assertEqualToResult (collapse (get-atoms &stk)) (()))
