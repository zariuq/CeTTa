!(import! &self mork)
!(bind! &h (new-space hash))
!(space-set-backend! &h pathmap)
!(add-atom &h (edge a b))
!(add-atom &h (edge b c))
!(add-atom &h (edge c d))
!(let* (($dropped (space-pop &h))
        (() (assertEqualToResult (size &h) (2)))
        (() (assertEqualToResult (match &h $dropped hit) ()))
        (() (space-set-backend! &h native-candidate-exact))
        (() (assertEqualToResult (size &h) (2)))
        (() (assertEqualToResult (match &h $dropped hit) ())))
   ())
!(space-set-backend! &h pathmap)
!(space-truncate &h 0)
!(assertEqualToResult (size &h) (0))
!(assertEqualToResult (match &h (edge $x $y) ($x $y)) ())
!(space-set-backend! &h native-candidate-exact)
!(assertEqualToResult (size &h) (0))
