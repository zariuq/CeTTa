!(import! &self list_expr)

!(assertEqual (expr-empty? ()) True)
!(assertEqual (expr-empty? (a b)) False)
!(assertEqual (expr-head (a b c)) a)
!(assertEqual (expr-tail (a b c)) (b c))
!(assertEqual (expr-length (a b c)) 3)
!(assertEqual (expr-get (a b c) 1) b)
!(assertEqual (expr-cons z (a b)) (z a b))
!(assertEqual (expr-snoc (a b) c) (a b c))
!(assertEqual (expr-append (a b) (c d)) (a b c d))
!(assertEqual (expr-reverse (a b c)) (c b a))
!(assertEqual (expr-map (1 2 3) $x (+ $x 1)) (2 3 4))
!(assertEqual (expr-filter (1 2 3 4) $x (> $x 2)) (3 4))
!(assertEqual (expr-foldl (1 2 3 4) 0 $acc $item (+ $acc $item)) 10)
