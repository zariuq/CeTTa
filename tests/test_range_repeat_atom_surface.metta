!(assertEqual (range-atom 5) (0 1 2 3 4))
!(assertEqual (range-atom 2 6) (2 3 4 5))
!(assertEqual (range-atom 5 2) ())
!(assertEqual (repeat-atom 3 z) (z z z))
!(assertEqual (repeat-atom 0 z) ())

!(assertEqualToResult (range-atom)
  ((Error (range-atom) IncorrectNumberOfArguments)))
!(assertEqualToResult (range-atom 1 2 3)
  ((Error (range-atom 1 2 3) IncorrectNumberOfArguments)))
!(assertEqualToResult (range-atom "s")
  ((Error (range-atom "s") (BadArgType 1 Number String))))
!(assertEqualToResult (range-atom 1 "s")
  ((Error (range-atom 1 "s") (BadArgType 2 Number String))))
!(assertEqualToResult (repeat-atom 1)
  ((Error (repeat-atom 1) IncorrectNumberOfArguments)))
!(assertEqualToResult (repeat-atom "s" z)
  ((Error (repeat-atom "s" z) (BadArgType 1 Number String))))
