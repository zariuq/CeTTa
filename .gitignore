/bench_mork.metta
/bench_native.metta
/bench_pathmap.metta

# Local Python caches
/scripts/__pycache__/
/tests/support/__pycache__/
/tests/support/import_foreign_pkg/plugin/__pycache__/

# Native/Rust build products
/native/*.o
/native/*.stage0.o
/src/*.o
/src/*.stage0.o
/rust/target/
