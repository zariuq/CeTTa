# Local runtime generated files and test scratch space.
# Keep real runtime source files trackable by default.
/runtime/bootstrap/build_config.h
/runtime/*.d
/runtime/*.o
/runtime/_tmp_*
/runtime/tmp_*
/runtime/git_module_fixture/
/runtime/test-git-module-cache/
