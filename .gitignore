/runtime/test_*_output.txt
/runtime/test_*.act
/runtime/test_space_term_universe_membership
/runtime/test_term_universe_store_abi
/runtime/test_variant_shape_roundtrip
/runtime/repro_*.mm

# Profiling and result artifacts
/massif.out.*
/profiling/
/results/

# Local checkpoints and backups
/src/*.checkpoint_*
/src/*.old_backup

# Local tool/session debris
/.codex
/.generated/
/.translator_pln_stage/
/.oruzhi_*/
/.oruzhi_*.metta
/.tmp_*.metta
/.cetta_*.metta
/tmp_*.metta
/tmp_cetta_logs/
